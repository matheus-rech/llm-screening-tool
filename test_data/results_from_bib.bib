@article{Sinha2022,
 abstract = {BACKGROUND AND AIMS: The pectoral nerve (PECS) block is a viable alternative to the thoracic paravertebral block (TPVB) for providing analgesia in breast cancer surgery. This study was conducted to compare the analgesic efficacy and adverse effects of ultrasound-guided TPVB and PECS block in patients undergoing modified radical mastectomy (MRM). METHODS: This prospective, randomised, double-blind study included 60 American Society of Anesthesiologists physical status I and II female patients aged 18-65 years scheduled for unilateral MRM. The patients were randomly allocated into two groups of 30 each. Group P received ultrasound-guided PECS block with 30 mL of 0.25% bupivacaine, and Group T received ultrasound-guided TPVB with 20 mL of 0.25% bupivacaine before the induction of general anaesthesia. The primary outcome was total rescue analgesic (fentanyl) consumption in the first 24 h post-operatively. The secondary outcomes were post-operative visual analogue scale (VAS) scores, time to first rescue analgesic, intraoperative fentanyl requirement, haemodynamic parameters, and adverse effects. RESULTS: The total consumption of fentanyl in the first 24 h was significantly lower in Group T (105.2 ± 20.3 μg) than in Group P (130.6 ± 25.4 μg) (P = 0.001). The intraoperative fentanyl requirement was comparable. The VAS scores at rest and on movement were significantly lower in Group T at 4, 8, 12 and 24 h. Time to first rescue analgesic was significantly longer in group T. Nausea and vomiting were comparable between the groups. CONCLUSION: TPVB is more effective than PECS block for post-operative analgesia in patients after MRM.},
 author = {Sinha, C and Kumar, A and Kumar, A and Kumari, P and Singh, A K and Kumar, A and Kumar, A},
 journal = {Indian journal of anaesthesia},
 note = {Screening Status: agreement, Decision: include},
 title = {Ultrasound-guided pectoral nerve block is an effective analgesic alternative to thoracic paravertebral block for breast cancer surgery: A randomised controlled trial.},
 year = {2022}
}
