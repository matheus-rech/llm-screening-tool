# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here
PORT=5000

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration  
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Email for PubMed API access (required for PMID fetching)
ENTREZ_EMAIL=your-email@domain.com

# Database Configuration (optional - defaults to SQLite)
DATABASE_URL=sqlite:///screening_projects.db

# Optional: Custom upload/results directories
UPLOAD_FOLDER=uploads
RESULTS_FOLDER=results
CONFIG_TEMPLATES_FOLDER=config_templates